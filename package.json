{
  "name": "tantuui",
  "private": true,
  "version": "0.0.6",
  "description": "TantuUI — token-based design system",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "storybook": "npm run storybook --workspace=packages/react",
    "deploy:storybook": "bash packages/react/scripts/deploy-storybook.sh",
    "publish-tokens": "npm run clean --workspace=packages/tokens && npm run build --workspace=packages/tokens && npm publish --workspace=packages/tokens --access public",
    "publish-react": "npm run clean && npm run build && npm publish --workspace=packages/react --access public"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
