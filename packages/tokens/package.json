{
  "name": "@tantuui/tokens",
  "version": "0.0.4",
  "description": "Framework-agnostic design tokens for TantuUI (--tui-* CSS variables)",
  "license": "MIT",
  "keywords": [
    "design-tokens",
    "css-variables",
    "design-system",
    "tantuui",
    "tailwind-preset",
    "theming"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./css": "./dist/tokens.css",
    "./css/base": "./dist/base.css",
    "./css/utilities": "./dist/utilities.css",
    "./tailwind-preset": "./dist/tailwind-preset.js",
    "./runtime": {
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pawan-rocks/tantuUI",
    "directory": "packages/tokens"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "export:figma": "node scripts/export-figma.js"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.5"
  }
}
